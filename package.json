{
  "name": "kas-bot-be",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node server.js",
    "prod": "pm2 start ecosystem.config.cjs --env production",
    "dev": "nodemon server.js",
    "stop": "pm2 stop kasbot",
    "restart": "pm2 restart kasbot",
    "logs": "pm2 logs kasbot",
    "status": "pm2 status",
    "checkM": "node check-models.js",
    "checkDB": "node test-db-mysql.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --forceExit",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPatterns=tests/unit",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPatterns=tests/integration --forceExit",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --forceExit",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch --testPathPatterns=tests/unit",
    "lint": "eslint ."
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testTimeout": 15000
  },
  "overrides": {
    "sharp": "0.33.3"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@adiwajshing/keyed-db": "^0.2.4",
    "@fastify/static": "^9.0.0",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.98.0",
    "@whiskeysockets/baileys": "github:WhiskeySockets/Baileys",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.70.4",
    "dotenv": "^17.3.1",
    "eventemitter2": "^6.4.9",
    "fastify": "^5.7.4",
    "form-data": "^4.0.5",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.19.0",
    "node-fetch": "^3.3.2",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "eslint": "^10.0.2",
    "jest": "^30.2.0",
    "nodemon": "^3.1.14"
  }
}
