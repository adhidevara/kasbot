# ─────────────────────────────────────────────────────────────────────────────
# KASBOT — Environment Variables
# Copy file ini ke .env dan isi sesuai konfigurasi kamu
# ─────────────────────────────────────────────────────────────────────────────

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Ganti dengan string random panjang untuk keamanan JWT
JWT_SECRET=your_jwt_secret_key # openssl rand -base64 64

# Level log: silent | error | warn | info | verbose
# info    → rekomendasi production
# verbose → rekomendasi development
LOG_LEVEL=info

# ─── WhatsApp Admin ─────────────────────────────────────────────────────────────────
ADMIN_WA=6281234567890@s.whatsapp.net

# ─── AI / ML ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_google_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash-lite

OPENAI_API_KEY=your_openai_api_key
GOOGLE_VISION_API_KEY=your_google_vision_api_key

# ─── Database ─────────────────────────────────────────────────────────────────
# Pilih driver: supabase | mysql
DB_DRIVER=mysql

# MySQL (aktif jika DB_DRIVER=mysql)
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=kala_db
DB_USERNAME=root
DB_PASSWORD=

# Supabase (aktif jika DB_DRIVER=supabase)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# ─── Redis ────────────────────────────────────────────────────────────────────
# Lokal
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Railway (isi jika deploy ke Railway, kosongkan jika lokal)
REDIS_URL=
REDISHOST=
REDISPORT=
REDISPASSWORD=
REDISUSER=