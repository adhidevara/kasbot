# Server Config
PORT=3000
NODE_ENV=development
DOC_KEY=your_secure_doc_key_here

# Level log yang ditampilkan di terminal
# silent  → tidak ada log sama sekali
# error   → hanya error kritis
# warn    → error + peringatan (rate limit, disconnect, dll)
# info    → + status koneksi, transaksi berhasil, pesan terkirim (REKOMENDASI PRODUCTION)
# verbose → semua log termasuk detail pesan, hasil AI, OCR, STT (REKOMENDASI DEVELOPMENT)
LOG_LEVEL=info

# AI API Keys
GEMINI_API_KEY=your_google_gemini_api_key # Jika pakai Google Gemini
GEMINI_MODEL=gemini-2.5-flash-lite # Model Gemini yang digunakan (opsional, default: gemini-2.0-flash)

OPENAI_API_KEY=your_openai_api_key # Jika pakai Whisper

GOOGLE_VISION_API_KEY=your_key_here # Jika pakai Vision API


# Supabase Config (Cek di Project Settings -> API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# Untuk admin WhatsApp
ADMIN_WA=6281234567890@s.whatsapp.net

# Redis Config (Opsional, untuk caching dan session management yang lebih baik)
REDIS_URL=redis://default:password@host:port
REDISHOST=xxx.railway.internal
REDISPORT=6379
REDISPASSWORD=xxxxxxxxxx
REDISUSER=default